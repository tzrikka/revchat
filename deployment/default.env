# Probably need to change these for your environment.

WEBHOOK_ADDRESS=XXX-YYY-ZZZ.ngrok-free.app

TIMPANI_THRIPPY_LINK_BITBUCKET=
TIMPANI_THRIPPY_LINK_JIRA=
TIMPANI_THRIPPY_LINK_GITHUB=
TIMPANI_THRIPPY_LINK_SLACK=

REVCHAT_BITBUCKET_WORKSPACE=
REVCHAT_SLACK_ALERTS_CHANNEL=
REVCHAT_SLACK_PRIVATE_CHANNELS=false
REVCHAT_THRIPPY_LINKS_TEMPLATE_ID=
REVCHAT_LINKIFICATION_MAP=

VOLUME_OTEL_LGTM_DATA=${HOME}/docker-volumes/revchat/otel-lgtm-data
VOLUME_POSTGRES_DATA=${HOME}/docker-volumes/revchat/postgres-data
VOLUME_REVCHAT_DATA=${HOME}/docker-volumes/revchat/revchat-data
VOLUME_THRIPPY_DATA=${HOME}/docker-volumes/revchat/thrippy-data
VOLUME_TIMPANI_DATA=${HOME}/docker-volumes/revchat/timpani-data

# Probably no need to change these, but still here for visibility / easy access.

TIMPANI_PORT=14480

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS_AUTH_ENABLED=true
GRAFANA_ANONYMOUS_AUTH_ORG_ROLE=Admin
GRAFANA_DISABLE_LOGIN_FORM=true
GRAFANA_PORT=3000
LOKI_PORT=3100

POSTGRES_VERSION=18-alpine
POSTGRES_PORT=5432
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal
POSTGRES_DB=temporal

REVCHAT_SLACK_CHANNEL_NAME_MAX_LENGTH=50
REVCHAT_SLACK_CHANNEL_NAME_PREFIX=_pr

TEMPORAL_ADMINTOOLS_VERSION=1.29
TEMPORAL_SERVER_VERSION=1.29
TEMPORAL_UI_VERSION=latest
TEMPORAL_NAMESPACE=default
TEMPORAL_SERVER_PORT=7233
TEMPORAL_UI_PORT=8233
